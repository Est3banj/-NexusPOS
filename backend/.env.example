# NexusPOS Environment Variables
# Copia este archivo a .env y completa los valores

# =============================================================================
# SERVIDOR
# =============================================================================
PORT=10000
HOST=0.0.0.0
NODE_ENV=development

# =============================================================================
# BASE DE DATOS
# =============================================================================
# Desarrollo local (SQLite) - NO incluir DATABASE_URL
# DB_PATH=./data/pos.db

# Producción (Supabase PostgreSQL) - Descomenta y configura
# DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================================================
# FRONTEND (para CORS)
# =============================================================================
# URL del frontend en producción
# FRONTEND_URL=https://tu-dominio.vercel.app

# =============================================================================
# FACTURACIÓN ELECTRÓNICA (FACTUS)
# =============================================================================
# API key de Factus (obtener en https://factus.com.co)
# FACTUS_API_KEY=tu_api_key_aqui

# Datos de tu empresa (para facturación electrónica)
# COMPANY_NIT=1234567890
# COMPANY_NAME=Tu Empresa SAS
# COMPANY_ADDRESS=Carrera 10 # 20-30
# COMPANY_CITY=Bogotá
# COMPANY_DEPT=Cundinamarca
# COMPANY_PHONE=3001234567
# COMPANY_EMAIL=facturas@tuempresa.com
# COMPANY_REGIMEN=Común
# COMPANY_ACTIVITY=4690

# =============================================================================
# JWT (opcional - el token se genera internamente)
# =============================================================================
# JWT_SECRET=tu_secret_muy_seguro_aqui